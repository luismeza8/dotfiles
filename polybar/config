[colors]
;background = ${xrdb:color0:#222}
background = #e6282828
background-alt = #4c566a
;foreground = ${xrdb:color7:#222}
foreground = #fbf1c7
foreground-alt = #ffffff
primary = #458588
secondary = #e60053
alert = #bd2c40

[bar/example]
;monitor = ${env:MONITOR:HDMI-1}
width = 100%
height = 32
;offset-x = 1%
;offset-y = 1%
;radius = 0
fixed-center = true

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 2
line-color = #f00

border-size = 0
border-color = #00000000
border-bottom-size = 0

padding-left = 0
padding-right = 2

module-margin-left = 1
module-margin-right = 2

font-0 = fixed:pixelsize=10;1
font-1 = unifont:fontformat=truetype:size=8:antialias=false;0
font-2 = siji:pixelsize=10;1
font-3 = Twemoji:scale=6;2
font-4 = FiraCode Nerd Font:style=Bold:antialias=true:scale=5;2
font-5 = "Material Icons Outlined:9;5"
font-6 = "Material Icons Round:9;8"

modules-left = bspwm
modules-center = mpd xwindow
modules-right = pulseaudio cpu battery date

tray-position = right
tray-padding = 2
;tray-background = #0063ff
wm-restack = bspwm

;override-redirect = true

scroll-up = bspwm-desknext
scroll-down = bspwm-deskprev

cursor-click = pointer
cursor-scroll = ns-resize

[module/xwindow]
type = internal/xwindow
label = "%title%"

label-indicator-padding = 2
label-indicator-margin = 1
label-indicator-background = ${colors.secondary}
